# CMS Delivery SDK Configuration
EELZAP_API_KEY=cms_secret_your_key_here

# Optional: override the default base URL (https://api.eelzap.com)
# Useful for local development or self-hosted deployments.
# EELZAP_BASE_URL=http://localhost:3000

# Optional: override the default path prefix (/v1)
# Useful when calling the Next.js app directly in local development.
# EELZAP_PATH_PREFIX=/api/public/v1
